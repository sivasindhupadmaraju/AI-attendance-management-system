# .env.example – copy this to .env and fill in the values

# Secret key used for JWT signing (replace with a strong random string)
SECRET_KEY=your-very-secret-key

# Database URL – Render will provide a writable filesystem, keep SQLite for dev
# For production you could use Postgres, e.g. postgres://user:pass@host/dbname
DATABASE_URL=sqlite:///./attendance.db

# (Optional) Any other env vars used by the app can be added here
